# Anthropic / compatible API
ANTHROPIC_API_KEY=your_api_key_here

# Tavily search API (https://tavily.com) — required for web search during writing
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: use a custom base URL (e.g. for compatible providers)
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# MODEL_ID=claude-opus-4-6

# Optional: override SQLite database path (default: ./data/vibe_writer.db)
# DATABASE_URL=sqlite+aiosqlite:///./data/vibe_writer.db
